---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/customers', label: 'Customers' },
  { href: '/about', label: 'About' },
  { href: '/deepweave', label: 'DeepWeave' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<nav class="nav">
  <a href="/" class="nav__logo" aria-label="Home">
    <img src="/favicon.svg" alt="" width="28" height="28" />
  </a>

  <button class="nav__toggle" aria-label="Open menu" aria-expanded="false" id="nav-toggle">
    <span></span>
    <span></span>
    <span></span>
  </button>

  <ul class="nav__links" id="nav-links">
    {navLinks.map((link) => (
      <li>
        <a
          href={link.href}
          class={`nav__link ${currentPath === link.href ? 'nav__link--active' : ''}`}
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>

  <button class="nav__close" aria-label="Close menu" id="nav-close">&times;</button>
</nav>

<style>
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 1.5rem;
    background-color: var(--color-linen);
    color: var(--color-midnight);
    position: relative;
    z-index: 100;
  }

  .nav__logo img {
    display: block;
  }

  .nav__links {
    display: flex;
    gap: 2rem;
    list-style: none;
  }

  .nav__link {
    font-size: var(--text-ui);
    color: var(--color-midnight);
    padding-bottom: 4px;
  }

  .nav__link:hover {
    color: var(--color-emerald);
  }

  .nav__link--active {
    border-bottom: 2px solid var(--color-gold);
  }

  .nav__toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .nav__toggle span {
    width: 24px;
    height: 2px;
    background-color: var(--color-midnight);
  }

  .nav__close {
    display: none;
    position: absolute;
    top: 1.25rem;
    right: 1.5rem;
    background: none;
    border: none;
    font-size: 2rem;
    color: var(--color-midnight);
    cursor: pointer;
    line-height: 1;
  }

  @media (max-width: 768px) {
    .nav__toggle {
      display: flex;
    }

    .nav__links {
      display: none;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2rem;
      position: fixed;
      inset: 0;
      background-color: var(--color-linen);
      z-index: 200;
    }

    .nav__links.nav__links--open {
      display: flex;
    }

    .nav__link {
      font-size: var(--text-h3);
    }

    .nav__close.nav__close--open {
      display: block;
      z-index: 201;
    }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const close = document.getElementById('nav-close');
  const links = document.getElementById('nav-links');

  toggle?.addEventListener('click', () => {
    links?.classList.add('nav__links--open');
    close?.classList.add('nav__close--open');
    toggle.setAttribute('aria-expanded', 'true');
  });

  close?.addEventListener('click', () => {
    links?.classList.remove('nav__links--open');
    close.classList.remove('nav__close--open');
    toggle?.setAttribute('aria-expanded', 'false');
  });
</script>
