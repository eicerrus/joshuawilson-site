---
interface Props {
  title: string;
  date: string;
  url: string;
  description: string;
}

const { title, date, url, description } = Astro.props;

function toEmbedUrl(youtubeUrl: string) {
  const idMatch = youtubeUrl.match(/(?:v=|youtu\.be\/)([^&?]+)/);
  const id = idMatch ? idMatch[1] : '';
  return `https://www.youtube.com/embed/${id}`;
}

const embedUrl = toEmbedUrl(url);
const formattedDate = new Date(date).toLocaleDateString('en-NZ', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="video-card">
  <div class="video-card__embed">
    <iframe
      src={embedUrl}
      title={title}
      frameborder="0"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen
    ></iframe>
  </div>
  <h3 class="video-card__title">{title}</h3>
  <p class="video-card__date">{formattedDate}</p>
  <p class="video-card__description">{description}</p>
</article>

<style>
  .video-card__embed {
    position: relative;
    width: 100%;
    padding-top: 56.25%;
    margin-bottom: 1rem;
  }

  .video-card__embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .video-card__title {
    font-size: var(--text-h3);
    margin-bottom: 0.25rem;
  }

  .video-card__date {
    font-size: var(--text-ui);
    color: var(--color-emerald);
    margin-bottom: 0.5rem;
  }
</style>
