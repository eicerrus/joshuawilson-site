---
interface Props {
  href: string;
  label: string;
  light?: boolean;
}

const { href, label, light = false } = Astro.props;
---

<a href={href} class="cta" class:list={[{ 'cta--light': light }]}>
  {label} <span class="cta__arrow">→</span>
</a>

<style>
  .cta {
    font-family: var(--font-body);
    color: var(--color-midnight);
    font-size: var(--text-body);
    display: inline-block;
  }

  .cta--light {
    color: white;
  }

  .cta:hover {
    color: var(--color-emerald);
    text-decoration: underline;
  }

  .cta__arrow {
    display: inline-block;
  }
</style>
